<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ResHog.UI.ViewModels"
             xmlns:ctl="using:ResHog.UI.Controls"
             xmlns:cvt="using:ResHog.UI.Converters"
             xmlns:dto="using:ResHog.Shared.Dtos"
             x:Class="ResHog.UI.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16" Spacing="16">

            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="系统概览" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1"
                           FontSize="12" Foreground="#888" VerticalAlignment="Center">
                    <Run Text="最后更新: " />
                    <Run Text="{Binding LastUpdate, StringFormat='{}{0:HH:mm:ss}'}" />
                </TextBlock>
            </Grid>

            <!-- Overview cards: 2x2 grid -->
            <UniformGrid Columns="2" Rows="2">

                <!-- CPU Card -->
                <Border Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource CardBorder}"
                        BorderThickness="1" CornerRadius="8" Padding="20,14" Margin="0,0,8,8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="CPU 总占用" FontSize="13" Foreground="#666" />
                        <TextBlock Text="{Binding CpuPercent, StringFormat='{}{0:F1}%'}"
                                   FontSize="32" FontWeight="Bold" Foreground="#D85A30" />
                        <ctl:UsageBar Value="{Binding CpuPercent}"
                                      MaxValue="100"
                                      BarColor="{DynamicResource CpuBarColor}"
                                      Height="22" />
                        <TextBlock Text="{Binding TotalProcesses, StringFormat='{}{0} 个进程'}"
                                   FontSize="11" Foreground="#999" />
                    </StackPanel>
                </Border>

                <!-- Memory Card -->
                <Border Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource CardBorder}"
                        BorderThickness="1" CornerRadius="8" Padding="20,14" Margin="8,0,0,8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="内存使用" FontSize="13" Foreground="#666" />
                        <TextBlock FontSize="32" FontWeight="Bold" Foreground="#378ADD">
                            <TextBlock.Text>
                                <Binding Path="MemoryMb" Converter="{x:Static cvt:MemoryFormatConverter.Instance}" />
                            </TextBlock.Text>
                        </TextBlock>
                        <ctl:UsageBar Value="{Binding MemoryMb}"
                                      MaxValue="32768"
                                      BarColor="{DynamicResource MemBarColor}"
                                      DisplayText="{Binding MemoryMb, StringFormat='{}{0:F0} MB'}"
                                      Height="22" />
                        <TextBlock Text="{Binding TotalThreads, StringFormat='{}{0:N0} 线程'}"
                                   FontSize="11" Foreground="#999" />
                    </StackPanel>
                </Border>

                <!-- I/O Read Card -->
                <Border Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource CardBorder}"
                        BorderThickness="1" CornerRadius="8" Padding="20,14" Margin="0,8,8,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="磁盘读取" FontSize="13" Foreground="#666" />
                        <TextBlock Text="{Binding IoReadMbS, StringFormat='{}{0:F1} MB/s'}"
                                   FontSize="32" FontWeight="Bold" Foreground="#1D9E75" />
                        <ctl:UsageBar Value="{Binding IoReadMbS}"
                                      MaxValue="100"
                                      BarColor="{DynamicResource IoBarColor}"
                                      Height="22" />
                        <TextBlock Text="{Binding TotalHandles, StringFormat='{}{0:N0} 句柄'}"
                                   FontSize="11" Foreground="#999" />
                    </StackPanel>
                </Border>

                <!-- I/O Write Card -->
                <Border Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource CardBorder}"
                        BorderThickness="1" CornerRadius="8" Padding="20,14" Margin="8,8,0,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="磁盘写入" FontSize="13" Foreground="#666" />
                        <TextBlock Text="{Binding IoWriteMbS, StringFormat='{}{0:F1} MB/s'}"
                                   FontSize="32" FontWeight="Bold" Foreground="#1D9E75" />
                        <ctl:UsageBar Value="{Binding IoWriteMbS}"
                                      MaxValue="100"
                                      BarColor="{DynamicResource IoBarColor}"
                                      Height="22" />
                        <TextBlock Text="实时刷新 2s"
                                   FontSize="11" Foreground="#999" />
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- Top CPU processes -->
            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="16,12">
                <StackPanel Spacing="8">
                    <TextBlock Text="Top 5 CPU 占用进程" FontSize="15" FontWeight="SemiBold" />
                    <ItemsControl ItemsSource="{Binding TopCpu}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="dto:ProcessSummaryDto">
                                <Grid ColumnDefinitions="160,*,80" Margin="0,3" Height="24">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding ProcessName}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                    <ctl:UsageBar Grid.Column="1"
                                                  Value="{Binding CpuPercent}"
                                                  MaxValue="100"
                                                  BarColor="{DynamicResource CpuBarColor}"
                                                  DisplayText="{Binding CpuPercent, StringFormat='{}{0:F1}%'}"
                                                  Margin="8,0" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding ServiceName}"
                                               FontSize="11"
                                               Foreground="#888"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Top Memory processes -->
            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="16,12">
                <StackPanel Spacing="8">
                    <TextBlock Text="Top 5 内存占用进程" FontSize="15" FontWeight="SemiBold" />
                    <ItemsControl ItemsSource="{Binding TopMemory}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="dto:ProcessSummaryDto">
                                <Grid ColumnDefinitions="160,*,80" Margin="0,3" Height="24">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding ProcessName}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                    <ctl:UsageBar Grid.Column="1"
                                                  Value="{Binding WorkingSetMb}"
                                                  MaxValue="2048"
                                                  BarColor="{DynamicResource MemBarColor}"
                                                  Margin="8,0">
                                        <ctl:UsageBar.DisplayText>
                                            <Binding Path="WorkingSetMb" StringFormat="{}{0:F0} MB" />
                                        </ctl:UsageBar.DisplayText>
                                    </ctl:UsageBar>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding ServiceName}"
                                               FontSize="11"
                                               Foreground="#888"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
