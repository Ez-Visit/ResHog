<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ResHog.UI.ViewModels"
        xmlns:views="using:ResHog.UI.Views"
        xmlns:cvt="using:ResHog.UI.Converters"
        x:Class="ResHog.UI.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="ResHog 资源监控"
        Icon="avares://ResHog.UI/Assets/app.png"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="*,Auto">

        <TabControl Grid.Row="0"
                    SelectedIndex="{Binding SelectedTabIndex}"
                    Margin="0">

            <TabItem Header="仪表盘">
                <views:DashboardView DataContext="{Binding Dashboard}" />
            </TabItem>

            <TabItem Header="进程管理">
                <views:ProcessManagerView DataContext="{Binding ProcessManager}" />
            </TabItem>

            <TabItem Header="Top-N 排行">
                <views:TopNView DataContext="{Binding TopN}" />
            </TabItem>

            <TabItem Header="趋势分析">
                <views:TrendView DataContext="{Binding Trend}" />
            </TabItem>

            <TabItem Header="告警">
                <views:AlertView DataContext="{Binding Alerts}" />
            </TabItem>

        </TabControl>

        <!-- Status bar -->
        <Border Grid.Row="1"
                Background="{DynamicResource StatusBarBackground}"
                BorderBrush="{DynamicResource CardBorder}"
                BorderThickness="0,1,0,0"
                Padding="12,6">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10"
                             Fill="{Binding IsServiceOnline, Converter={x:Static cvt:BoolToStatusBrushConverter.Instance}}" />
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="12"
                               Foreground="#333" />
                    <ProgressBar IsVisible="{Binding IsChecking}"
                                 IsIndeterminate="True"
                                 Width="12" Height="12"
                                 VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ResponseTimeText}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#555"
                               VerticalAlignment="Center" />
                    <TextBlock Text="ResHog v0.2.2"
                               FontSize="11"
                               Foreground="#999"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

    </Grid>

</Window>
