{
  "//": "ResHog config template - install.ps1 copies this to appsettings.json, replacing {{DATA_DIR}} with the actual data directory",
  "ResHog": {
    "SampleIntervalSec": 3,
    "DbPath": "{{DATA_DIR}}\\data.db",
    "LogPath": "{{DATA_DIR}}\\logs",
    "ReportPath": "{{DATA_DIR}}\\reports",

    "Retention": {
      "RawDataDays": 2,
      "MinuteAggregationDays": 7
    },

    "Alerts": {
      "CpuWarningPercent": 30,
      "CpuCriticalPercent": 60,
      "MemoryWarningMb": 512,
      "MemoryCriticalMb": 1024,
      "IoWarningMbPerSec": 5,
      "IoCriticalMbPerSec": 20,
      "ThreadWarningCount": 200,
      "ThreadCriticalCount": 500,
      "HandleWarningCount": 5000,
      "HandleCriticalCount": 20000,
      "AlertCooldownMin": 5
    },

    "Exclusions": {
      "ProcessNames": [ "Idle", "_Total", "System" ],
      "MinCpuPercent": 0.1,
      "MinMemoryMb": 1.0
    },

    "Api": {
      "Enabled": true,
      "Port": 5180
    }
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "{{DATA_DIR}}\\logs\\reshog-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  }
}
