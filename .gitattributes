# .gitattributes
# https://git-scm.com/docs/gitattributes

# 默认行为：自动检测文本/二进制
* text=auto

# 源代码文件使用 CRLF
*.cs      text eol=crlf
*.csproj  text eol=crlf
*.sln     text eol=crlf
*.axaml   text eol=crlf
*.xaml    text eol=crlf
*.json    text eol=crlf
*.xml     text eol=crlf
*.props   text eol=crlf
*.targets text eol=crlf

# 脚本文件
*.ps1     text eol=crlf
*.sh      text eol=lf
*.bat     text eol=crlf
*.cmd     text eol=crlf

# 配置文件
*.yml     text eol=lf
*.yaml    text eol=lf
*.editorconfig text eol=crlf
*.gitignore    text eol=lf
*.gitattributes text eol=lf

# Markdown / 文档
*.md      text eol=crlf

# 二进制文件（不做行尾转换）
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.pdf     binary
*.zip     binary
*.dll     binary
*.exe     binary
*.db      binary
*.db-wal  binary
*.db-shm  binary

# 语言学：GitHub 语言统计
# ResHog 主要是 C# 项目，确保正确识别
*.axaml   linguist-language=C#
*.csproj  linguist-language=XML

# 忽略文件
*.docx    linguist-generated=true
*.xlsx    linguist-generated=true
